rules_version = '2';

// Firestore Security Rules — Gileno Gestão Saúde
// Princípio: cada usuário só acessa o próprio documento.
// Modelo de dados: users/{uid} com campo `data` (JSON serializado) + `updatedAt`.
// Default-deny: qualquer path não listado aqui é bloqueado.

service cloud.firestore {
  match /databases/{database}/documents {

    // Documento principal do usuário — leitura/escrita só do dono autenticado
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Default deny: qualquer outro path retorna falso
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
