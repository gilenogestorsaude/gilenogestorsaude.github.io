rules_version = '2';

// Firestore Security Rules — Gileno Gestão Saúde
// Princípio: cada usuário só acessa o próprio documento.
// Modelo de dados: users/{uid} com campo `data` (JSON serializado) + `updatedAt`.
// Default-deny: qualquer path não listado aqui é bloqueado.

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin whitelist — emails autorizados a LER (não escrever) todos os users
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email_verified == true
             && request.auth.token.email == 'gilenopaivalima@gmail.com';
    }

    // Documento principal do usuário
    // - Dono autenticado: leitura E escrita do próprio doc
    // - Admin: leitura (incluindo list) de qualquer doc, SEM escrita
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId)
                  || isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // Default deny: qualquer outro path retorna falso
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
